# ========================================
# LifeVault AI Features Configuration
# ========================================

# Add this line to your `.env` file (in your project root)
# Replace 'hf_your_actual_token_here' with your actual Hugging Face token

HUGGINGFACE_API_KEY=hf_your_actual_token_here

# ========================================
# Example Complete .env (with Firebase)
# ========================================
# 
# APP_NAME=LifeVault
# APP_ENV=local
# APP_KEY=base64:...
# APP_DEBUG=true
# APP_URL=http://localhost
#
# # Firebase Configuration
# VITE_FIREBASE_API_KEY=your_firebase_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
# VITE_FIREBASE_APP_ID=1:123456789:web:abc123def456
# VITE_FIREBASE_MEASUREMENT_ID=G-ABC123DEF456
#
# # Hugging Face AI Configuration (ADD THIS!)
# HUGGINGFACE_API_KEY=hf_your_actual_token_here
#
# # Other configurations...
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=lifevault
# DB_USERNAME=root
# DB_PASSWORD=
#
# ========================================
# How to get your API token:
# ========================================
# 
# 1. Go to: https://huggingface.co/settings/tokens
# 2. Click "New token" button
# 3. Fill in:
#    - Token name: LifeVault AI
#    - Token type: Read
# 4. Click "Create token"
# 5. Copy the token (starts with "hf_")
# 6. Paste it in your .env file
#
# ========================================
# Commands to refresh configuration:
# ========================================
#
# php artisan cache:clear
# php artisan config:clear
#
# ========================================
